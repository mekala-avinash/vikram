{
  "$schema": "https://schema.management.azure.com/schemas/2016-06-01/Microsoft.Logic.json",
  "_comment": "STAGING environment parameters. All non-secret values are set here. Secrets use Azure Key Vault references — never hardcode real secrets.",

  "ServiceBusTopicName": {
    "type": "String",
    "value": "invoice-ready-for-transformation"
  },
  "ServiceBusSubscriptionName": {
    "type": "String",
    "value": "logicapp-transform"
  },
  "ServiceBusQueueName": {
    "type": "String",
    "value": "ksef-xml-ready-for-submission"
  },
  "XsltMapName": {
    "type": "String",
    "value": "KsefFa3.xslt"
  },
  "KsefAuthUrl": {
    "type": "String",
    "value": "https://login.smartksef-staging.exorigo-upos.pl/<STAGING_TENANT_ID>/B2C_1_susi/oauth2/v2.0/token"
  },
  "KsefClientId": {
    "type": "String",
    "value": "<STAGING_CLIENT_ID>"
  },
  "KsefClientSecret": {
    "type": "SecureString",
    "value": "@Microsoft.KeyVault(SecretUri=https://<YOUR_KEYVAULT_NAME>.vault.azure.net/secrets/KsefClientSecret-Staging/)"
  },
  "KsefScope": {
    "type": "String",
    "value": "https://login.smartksef-staging.exorigo-upos.pl/api/invoices/.default"
  },
  "KsefApiUrl": {
    "type": "String",
    "value": "https://api.smartksef-staging.exorigo-upos.pl/invoices"
  },
  "SqlConnectionString": {
    "type": "SecureString",
    "value": "@Microsoft.KeyVault(SecretUri=https://<YOUR_KEYVAULT_NAME>.vault.azure.net/secrets/SqlConnectionString-Staging/)"
  },
  "ServiceBusConnectionString": {
    "type": "SecureString",
    "value": "@Microsoft.KeyVault(SecretUri=https://<YOUR_KEYVAULT_NAME>.vault.azure.net/secrets/ServiceBusConnectionString-Staging/)"
  }
}
