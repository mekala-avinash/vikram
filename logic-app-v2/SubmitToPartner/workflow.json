{
    "definition": {
        "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
        "contentVersion": "1.0.0.0",
        "actions": {
            "Parse_Message": {
                "type": "ParseJson",
                "inputs": {
                    "content": "@base64ToString(triggerBody()?[0]?['ContentData'])",
                    "schema": {
                        "properties": {
                            "PartnerSubmissionId": {
                                "type": "integer"
                            }
                        },
                        "type": "object"
                    }
                },
                "runAfter": {}
            },
            "Get_Partner_XML": {
                "type": "ServiceProvider",
                "inputs": {
                    "parameters": {
                        "query": "SELECT PartnerSubmissionId, PartnerXML FROM [dbo].[PartnerSubmission] WHERE PartnerSubmissionId = @PartnerSubmissionId",
                        "queryParameters": {
                            "PartnerSubmissionId": "@body('Parse_Message')?['PartnerSubmissionId']"
                        }
                    },
                    "serviceProviderConfiguration": {
                        "connectionName": "sql",
                        "operationId": "executeQuery",
                        "serviceProviderId": "/serviceProviders/sql"
                    }
                },
                "runAfter": {
                    "Parse_Message": [
                        "Succeeded"
                    ]
                }
            },
            "Get_OAuth_Token": {
                "type": "Http",
                "inputs": {
                    "uri": "https://login.smartksef-staging.exorigo-upos.pl/d92dfc98-2b80-4938-97f5-d4bee2112678/oauth2/v2.0/token?p=B2C_1_susi_default",
                    "method": "POST",
                    "headers": {
                        "Content-Type": "application/x-www-form-urlencoded"
                    },
                    "body": "grant_type=client_credentials&client_id=@{appsetting('SMARTKSEF_CLIENT_ID')}&client_secret=@{appsetting('SMARTKSEF_CLIENT_SECRET')}&scope=https://login.smartksef-staging.exorigo-upos.pl/api/invoices/.default"
                },
                "runAfter": {
                    "Get_Partner_XML": [
                        "Succeeded"
                    ]
                }
            },
            "Parse_OAuth_Token": {
                "type": "ParseJson",
                "inputs": {
                    "content": "@body('Get_OAuth_Token')",
                    "schema": {
                        "properties": {
                            "access_token": {
                                "type": "string"
                            },
                            "token_type": {
                                "type": "string"
                            },
                            "expires_in": {
                                "type": "integer"
                            }
                        },
                        "type": "object"
                    }
                },
                "runAfter": {
                    "Get_OAuth_Token": [
                        "Succeeded"
                    ]
                }
            },
            "POST_to_KSeF_API": {
                "type": "Http",
                "inputs": {
                    "uri": "https://api.smartksef-staging.exorigo-upos.pl/invoices",
                    "method": "POST",
                    "headers": {
                        "Accept": "application/json",
                        "Authorization": "Bearer @{body('Parse_OAuth_Token')?['access_token']}",
                        "Content-Type": "application/x.ksef.invoice+xml",
                        "X-KSEF-SCHEMA": "FA3"
                    },
                    "body": "@body('Get_Partner_XML')?['resultSets'][0][0]['PartnerXML']"
                },
                "runAfter": {
                    "Parse_OAuth_Token": [
                        "Succeeded"
                    ]
                }
            },
            "Check_HTTP_Status": {
                "type": "If",
                "expression": {
                    "and": [
                        {
                            "greaterOrEquals": [
                                "@outputs('POST_to_KSeF_API')['statusCode']",
                                200
                            ]
                        },
                        {
                            "less": [
                                "@outputs('POST_to_KSeF_API')['statusCode']",
                                300
                            ]
                        }
                    ]
                },
                "actions": {
                    "Execute_usp_UpdatePartnerSubmissionStatus_Success": {
                        "type": "ServiceProvider",
                        "inputs": {
                            "parameters": {
                                "query": "EXEC [dbo].[usp_UpdatePartnerSubmissionStatus] @PartnerSubmissionId = @PartnerSubmissionId, @Status = 2, @KSeFReferenceNumber = @KSeFReferenceNumber",
                                "queryParameters": {
                                    "KSeFReferenceNumber": "@body('POST_to_KSeF_API')?['referenceNumber']",
                                    "PartnerSubmissionId": "@body('Parse_Message')?['PartnerSubmissionId']"
                                }
                            },
                            "serviceProviderConfiguration": {
                                "connectionName": "sql",
                                "operationId": "executeQuery",
                                "serviceProviderId": "/serviceProviders/sql"
                            }
                        }
                    }
                },
                "else": {
                    "actions": {
                        "Execute_usp_UpdatePartnerSubmissionStatus_Failed": {
                            "type": "ServiceProvider",
                            "inputs": {
                                "parameters": {
                                    "query": "EXEC [dbo].[usp_UpdatePartnerSubmissionStatus] @PartnerSubmissionId = @PartnerSubmissionId, @Status = 3, @ErrorMessage = @ErrorMessage",
                                    "queryParameters": {
                                        "ErrorMessage": "@substring(string(body('POST_to_KSeF_API')), 0, 500)",
                                        "PartnerSubmissionId": "@body('Parse_Message')?['PartnerSubmissionId']"
                                    }
                                },
                                "serviceProviderConfiguration": {
                                    "connectionName": "sql",
                                    "operationId": "executeQuery",
                                    "serviceProviderId": "/serviceProviders/sql"
                                }
                            }
                        }
                    }
                },
                "runAfter": {
                    "POST_to_KSeF_API": [
                        "Succeeded",
                        "Failed",
                        "TimedOut"
                    ]
                }
            }
        },
        "contentVersion": "1.0.0.0",
        "outputs": {},
        "triggers": {
            "When_message_arrives_in_queue": {
                "type": "ServiceProvider",
                "inputs": {
                    "parameters": {
                        "queueName": "ksef-xml-ready-for-submission"
                    },
                    "serviceProviderConfiguration": {
                        "connectionName": "serviceBus",
                        "operationId": "receiveQueueMessages",
                        "serviceProviderId": "/serviceProviders/serviceBus"
                    }
                }
            }
        }
    },
    "kind": "Stateful"
}