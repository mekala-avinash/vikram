# ============================================================
# KSeF Azure Integration — .gitignore
# ============================================================

# --- Secrets & Environment-local config ---
# Never commit real parameter files with secrets.
# Use environments/parameters.example.json as the template.
local.settings.json
*.secrets.json

# --- Azure Functions / Logic App local dev ---
.vscode/
host.json.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.python_packages/
.venv/
venv/
ENV/
env/

# --- Test outputs (generated — not source) ---
tests/output/
tests/**/*_output.xml
tests/**/*_result.xml

# --- OS metadata ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log

# --- Terraform (legacy — kept in case infra code is added) ---
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
!terraform.tfvars.example

# --- Scratch / local test files ---
input.xml
output.xml
*_output.xml
*_result.xml
