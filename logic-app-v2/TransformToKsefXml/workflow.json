{
    "definition": {
        "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
        "contentVersion": "1.0.0.0",
        "actions": {
            "Parse_CanonicalId": {
                "type": "ParseJson",
                "inputs": {
                    "content": "@string(triggerBody()?[0]?['contentData'])",
                    "schema": {
                        "type": "object",
                        "properties": {
                            "CanonicalId": {
                                "type": "integer"
                            }
                        }
                    }
                },
                "runAfter": {}
            },
            "Execute_a_SQL_query_(V2)": {
                "type": "ApiConnection",
                "inputs": {
                    "host": {
                        "connection": {
                            "referenceName": "sql"
                        }
                    },
                    "method": "post",
                    "body": {
                        "query": "SELECT CanonicalXML FROM [EDI].[InvoiceCanonicals] WHERE CanonicalId = @{body('Parse_CanonicalId')?['CanonicalId']}"
                    },
                    "path": "/v2/datasets/@{encodeURIComponent(encodeURIComponent('default'))},@{encodeURIComponent(encodeURIComponent('default'))}/query/sql"
                },
                "runAfter": {
                    "Parse_CanonicalId": [
                        "SUCCEEDED"
                    ]
                }
            },
            "Check_Row_Exists": {
                "type": "If",
                "expression": {
                    "and": [
                        {
                            "greater": [
                                "@length(coalesce(body('Execute_a_SQL_query_(V2)')?['ResultSets']?['Table1'], json('[]')))",
                                0
                            ]
                        }
                    ]
                },
                "actions": {
                    "Transform_XML": {
                        "type": "Xslt",
                        "inputs": {
                            "content": "@string(body('Execute_a_SQL_query_(V2)')?['ResultSets']?['Table1']?[0]?['CanonicalXML'])",
                            "map": {
                                "source": "LogicApp",
                                "name": "KsefFa3.xslt"
                            }
                        }
                    },
                    "Validate_XML": {
                        "type": "XmlValidation",
                        "inputs": {
                            "content": "@xml(substring(base64ToString(body('Transform_XML')?['$content']),indexOf(base64ToString(body('Transform_XML')?['$content']), '<'),sub(length(base64ToString(body('Transform_XML')?['$content'])),indexOf(base64ToString(body('Transform_XML')?['$content']), '<'))))",
                            "schema": {
                                "source": "LogicApp",
                                "name": "FA3_schemat.xsd"
                            }
                        },
                        "runAfter": {
                            "Transform_XML": [
                                "SUCCEEDED"
                            ]
                        }
                    },
                    "Upsert_PartnerSubmission": {
                        "type": "ServiceProvider",
                        "inputs": {
                            "parameters": {
                                "query": "EXEC [EDI].[InsertPartnerXml] @CanonicalId = @CanonicalId, @PartnerXml = @PartnerXml",
                                "queryParameters": {
                                    "CanonicalId": "@body('Parse_CanonicalId')?['CanonicalId']",
                                    "PartnerXml": "@string(xml(substring(base64ToString(body('Transform_XML')?['$content']),indexOf(base64ToString(body('Transform_XML')?['$content']), '<'),sub(length(base64ToString(body('Transform_XML')?['$content'])),indexOf(base64ToString(body('Transform_XML')?['$content']), '<')))))"
                                }
                            },
                            "serviceProviderConfiguration": {
                                "connectionName": "sql-2",
                                "operationId": "executeQuery",
                                "serviceProviderId": "/serviceProviders/sql"
                            }
                        },
                        "runAfter": {
                            "Validate_XML": [
                                "SUCCEEDED"
                            ]
                        }
                    },
                    "Send_Queue_Message": {
                        "type": "ServiceProvider",
                        "inputs": {
                            "parameters": {
                                "entityName": "ksef-xml-ready-for-submission",
                                "message": {
                                    "contentData": {
                                        "PartnerSubmissionId": "@body('Upsert_PartnerSubmission')?[0]?[0]?['SubmissionId']"
                                    },
                                    "sessionId": "@string(body('Parse_CanonicalId')?['CanonicalId'])",
                                    "messageId": "@guid()",
                                    "correlationId": "@string(body('Parse_CanonicalId')?['CanonicalId'])"
                                },
                                "queueName": "ksef-xml-ready-for-submission"
                            },
                            "serviceProviderConfiguration": {
                                "connectionName": "serviceBus",
                                "operationId": "sendMessage",
                                "serviceProviderId": "/serviceProviders/serviceBus"
                            }
                        },
                        "runAfter": {
                            "Upsert_PartnerSubmission": [
                                "SUCCEEDED"
                            ]
                        }
                    },
                    "Complete_Message_Success": {
                        "type": "ServiceProvider",
                        "inputs": {
                            "parameters": {
                                "topicName": "invoice-ready-for-transformation",
                                "subscriptionName": "logicapp-transform",
                                "lockToken": "@triggerBody()?[0]?['lockToken']"
                            },
                            "serviceProviderConfiguration": {
                                "connectionName": "serviceBus",
                                "operationId": "completeTopicMessageV2",
                                "serviceProviderId": "/serviceProviders/serviceBus"
                            }
                        },
                        "runAfter": {
                            "Send_Queue_Message": [
                                "SUCCEEDED"
                            ]
                        }
                    }
                },
                "else": {
                    "actions": {
                        "Terminate_No_Data": {
                            "type": "Terminate",
                            "inputs": {
                                "runStatus": "Cancelled"
                            }
                        }
                    }
                },
                "runAfter": {
                    "Execute_a_SQL_query_(V2)": [
                        "SUCCEEDED"
                    ]
                }
            }
        },
        "outputs": {},
        "triggers": {
            "When_messages_are_available_in_a_topic_subscription_(peek-lock)": {
                "type": "ServiceProvider",
                "inputs": {
                    "parameters": {
                        "topicName": "invoice-ready-for-transformation",
                        "subscriptionName": "logicapp-transform"
                    },
                    "serviceProviderConfiguration": {
                        "connectionName": "serviceBus",
                        "operationId": "peekLockTopicMessagesV2",
                        "serviceProviderId": "/serviceProviders/serviceBus"
                    }
                }
            }
        }
    },
    "kind": "Stateful"
}